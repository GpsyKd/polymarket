# Copy to `.env` and adjust. All variables are prefixed POLYBOT_.

# Mode: paper | live  (live requires the block at the bottom + pip install ".[live]")
POLYBOT_MODE=paper

# --- Bankroll & risk (USD) ---
POLYBOT_BANKROLL_USD=100
POLYBOT_MAX_POSITION_USD=15
POLYBOT_MAX_TOTAL_EXPOSURE_USD=80
POLYBOT_DAILY_LOSS_LIMIT_USD=20
# Minimum edge (probability points) required to place a bet
POLYBOT_MIN_EDGE=0.05

# --- Stage-0 screener thresholds ---
POLYBOT_SCREEN_MIN_LIQUIDITY_USD=1000
POLYBOT_SCREEN_MIN_VOLUME24H_USD=0
POLYBOT_SCREEN_MAX_DAYS_TO_RESOLVE=120
POLYBOT_SCREEN_MIN_HOURS_TO_RESOLVE=6
POLYBOT_SCREEN_MAX_SPREAD=0.08
POLYBOT_SCREEN_PRICE_LOW=0.05
POLYBOT_SCREEN_PRICE_HIGH=0.95
# Rotate scans through a pool this many times wider than --top, instead of
# re-scanning the same top-liquidity (= most efficiently priced) markets each tick
POLYBOT_SCAN_POOL_FACTOR=3

# --- Exits (flow-horizon positions ONLY; value bets are held to resolution) ---
POLYBOT_EXIT_TAKE_PROFIT=0.03
POLYBOT_EXIT_STOP_LOSS=0.05
POLYBOT_EXIT_MAX_HOLD_HOURS=48
# Flow entries pay ~the full spread round-trip: keep this well below the stop-loss
POLYBOT_FLOW_MAX_SPREAD=0.02
# Close positions stuck in a closed-but-never-resolved market after this grace period
POLYBOT_STALE_GRACE_HOURS=48

# --- Whale-flow signal ---
POLYBOT_WHALE_MIN_USD=500
# Ignore whale trades older than this — they are already priced in
POLYBOT_WHALE_MAX_AGE_MINUTES=90

# --- LLM (news-signal funnel; OpenAI-compatible endpoint, default xAI/Grok) ---
# POLYBOT_GROK_API_KEY=            # your xAI key (or set XAI_API_KEY / GROK_API_KEY)
POLYBOT_LLM_BASE_URL=https://api.x.ai/v1
# xAI model ids. grok-4.3 is the current default (1M ctx, ~$1.25/$2.50 per 1M tokens):
POLYBOT_LLM_TRIAGE_MODEL=grok-4.3
POLYBOT_LLM_DEEP_MODEL=grok-4.3
POLYBOT_LLM_LIVE_SEARCH=true
POLYBOT_LLM_MAX_DEEP=6
POLYBOT_LLM_MIN_CONFIDENCE=0.55
# Default loop interval for --strategy llm (news is slow; 5-min ticks just burn budget)
POLYBOT_LLM_INTERVAL_SECONDS=1800

# --- Telegram (control + notifications) ---
# POLYBOT_TELEGRAM_BOT_TOKEN=      # or TELEGRAM_BOT_TOKEN
# POLYBOT_TELEGRAM_CHAT_ID=        # or TELEGRAM_CHAT_ID (your user/chat id)

# --- Live execution (REAL MONEY — leave everything below unset for paper) ---
# POLYBOT_MODE=live                # switch paper -> live
# POLYBOT_POLYGON_PRIVATE_KEY=     # wallet private key (or env POLYGON_PRIVATE_KEY)
# POLYBOT_CLOB_SIGNATURE_TYPE=0    # 0=EOA, 1=email/Magic, 2=browser proxy
# POLYBOT_CLOB_FUNDER=             # proxy/funder address (signature types 1/2)
# POLYBOT_CLOB_SLIPPAGE=0.02       # max price above quote a live buy may fill at (limit-FAK cap)
# POLYBOT_LIVE_CONFIRM=            # set to I_UNDERSTAND_LIVE_RISK to actually place orders
# NOTE: use a separate POLYBOT_DB_PATH for live — paper and live ledgers must not share a file

POLYBOT_LOG_LEVEL=INFO
